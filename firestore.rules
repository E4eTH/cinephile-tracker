rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /media/{documentId} {
      function isValidMedia() {
        let data = request.resource.data;
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() < 200 &&
               data.type in ['movie', 'series'] &&
               (data.status in ['plan_to_watch', 'watching', 'completed', 'dropped']);
      }

      allow create: if request.auth != null && isValidMedia();
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && isValidMedia() && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
